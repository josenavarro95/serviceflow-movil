<?xml version='1.0' encoding='utf-8'?>
<widget id="com.praia.salon" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>PRAIA</name>
    <description>
        Sistema de Gestión de Citas para Salon - Sincronización en Tiempo Real
    </description>
    <author email="jota952009@gmail.com" href="https://praia-salon.com">
        PRAIA Development
    </author>
    <content src="index.html" />
    <plugin name="cordova-plugin-whitelist" spec="1" />
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />
    <platform name="android">
        <allow-intent href="market:*" />
        <preference name="android-minSdkVersion" value="21" />
        <preference name="android-targetSdkVersion" value="33" />
    </platform>
    <platform name="ios">
        <allow-intent href="itms:*" />
        <allow-intent href="itms-apps:*" />
        <preference name="UseSwiftLanguageVersion" value="5" />
    </platform>
    <preference name="Orientation" value="portrait" />
    <preference name="BackgroundColor" value="0xFFFFFFFF" />
    <preference name="ShowTitle" value="true" />
    <preference name="FadeSplashScreen" value="true" />
    <preference name="FadeSplashScreenDuration" value="3000" />
</widget>
